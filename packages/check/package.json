{
  "name": "@imachange/check",
  "version": "0.1.0",
  "description": "多言語対応のLint/Format統合ラッパーツール",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "imachange-check": "./dist/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/ tests/",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.3.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}

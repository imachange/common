{
  "line-length": 100,
  "indent-width": 4,
  "target-version": "py311",
  "select": ["E", "F", "W", "I", "N", "UP", "B", "SIM"],
  "ignore": ["E501"],
  "exclude": ["__pycache__", ".venv", "dist", "build", "*.egg-info"],
  "fix": false,
  "format": {
    "quote-style": "double",
    "magic-trailing-comma": "respect",
    "line-ending": "auto"
  }
}
